<view class="tab-bar">
  <view 
    class="tab-item {{currentIndex === 0 ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="0"
  >
    <image class="tab-icon" src="{{currentIndex === 0 ? list[0].selectedIconPath : list[0].iconPath}}" mode="aspectFit" />
    <text class="tab-text">{{list[0].text}}</text>
  </view>
  
  <view 
    class="tab-item {{currentIndex === 1 ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="1"
  >
    <image class="tab-icon" src="{{currentIndex === 1 ? list[1].selectedIconPath : list[1].iconPath}}" mode="aspectFit" />
    <text class="tab-text">{{list[1].text}}</text>
  </view>
  
  <view 
    class="tab-item {{currentIndex === 2 ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="2"
  >
    <image class="tab-icon" src="{{currentIndex === 2 ? list[2].selectedIconPath : list[2].iconPath}}" mode="aspectFit" />
    <text class="tab-text">{{list[2].text}}</text>
  </view>
  
  <view 
    class="tab-item {{currentIndex === 3 ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="3"
  >
    <image class="tab-icon" src="{{currentIndex === 3 ? list[3].selectedIconPath : list[3].iconPath}}" mode="aspectFit" />
    <text class="tab-text">{{list[3].text}}</text>
  </view>
</view>
