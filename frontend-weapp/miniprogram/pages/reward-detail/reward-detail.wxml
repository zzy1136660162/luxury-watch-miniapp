<view class="page">
  <view class="nav-bar">
    <view class="nav-bar-left" bindtap="onBack">
      <text class="back-arrow">‹</text>
    </view>
    <view class="nav-bar-title">礼品详情</view>
    <view class="nav-bar-right"></view>
  </view>

  <view class="content">
    <view class="reward-image-wrapper">
      <image class="reward-image" src="{{reward.image}}" mode="aspectFill" />
    </view>

    <view class="reward-info">
      <view class="reward-header">
        <text class="reward-title">{{reward.title}}</text>
        <text class="reward-subtitle">{{reward.subtitle}}</text>
      </view>

      <view class="points-section">
        <text class="points-label">所需积分</text>
        <text class="points-value">{{reward.points}}</text>
      </view>

      <view class="description-section">
        <text class="section-title">礼品说明</text>
        <text class="description-text">尊贵的会员您好，此礼品为会员专属权益，兑换后可在品牌门店领取。详情请咨询客服。</text>
      </view>

      <view class="notice-section">
        <text class="section-title">兑换须知</text>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">兑换成功后，客服将在3个工作日内与您联系</text>
        </view>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">请确保手机号码正确，以便接收兑换码</text>
        </view>
        <view class="notice-item">
          <text class="notice-dot">•</text>
          <text class="notice-text">此礼品仅限会员本人兑换使用</text>
        </view>
      </view>
    </view>

    <view class="bottom-bar">
      <button class="exchange-btn" bindtap="onExchange">立即兑换</button>
    </view>
  </view>

  <!-- 地址选择弹窗 -->
  <view wx:if="{{showAddressDialog}}" class="dialog-mask" bindtap="onCloseAddressDialog">
    <view class="dialog-content" catchtap="onDialogTap">
      <view class="dialog-header">
        <text class="dialog-title">选择收货地址</text>
        <text class="dialog-close" bindtap="onCloseAddressDialog">×</text>
      </view>
      <view class="dialog-body">
        <view wx:if="{{addressList.length === 0}}" class="no-address">
          <text>暂无收货地址，请新增</text>
        </view>
        <view wx:else class="address-list">
          <view wx:for="{{addressList}}" wx:key="index" class="address-item {{selectedAddressIndex === index ? 'selected' : ''}}" bindtap="onSelectAddress" data-index="{{index}}">
            <view class="address-info">
              <text class="address-name">{{item.name}}</text>
              <text class="address-phone">{{item.phone}}</text>
            </view>
            <text class="address-detail">{{item.address}}</text>
          </view>
        </view>
        <view class="add-address-btn" bindtap="onShowAddAddress">
          <text>+ 新增收货地址</text>
        </view>
      </view>
      <view class="dialog-footer">
        <button class="btn-confirm" bindtap="onConfirmAddress">确认</button>
      </view>
    </view>
  </view>

  <!-- 新增地址弹窗 -->
  <view wx:if="{{showAddAddressDialog}}" class="dialog-mask" bindtap="onCloseAddAddressDialog">
    <view class="dialog-content" catchtap="onDialogTap">
      <view class="dialog-header">
        <text class="dialog-title">新增收货地址</text>
        <text class="dialog-close" bindtap="onCloseAddAddressDialog">×</text>
      </view>
      <view class="dialog-body">
        <view class="form-item">
          <text class="form-label">收货人</text>
          <input class="form-input" value="{{newAddress.name}}" placeholder="请输入收货人姓名" bindinput="onInputName" />
        </view>
        <view class="form-item">
          <text class="form-label">联系电话</text>
          <input class="form-input" value="{{newAddress.phone}}" placeholder="请输入联系电话" bindinput="onInputPhone" type="number" maxlength="11" />
        </view>
        <view class="form-item">
          <text class="form-label">详细地址</text>
          <textarea class="form-textarea" value="{{newAddress.address}}" placeholder="请输入详细地址" bindinput="onInputAddress" />
        </view>
      </view>
      <view class="dialog-footer">
        <button class="btn-cancel" bindtap="onCloseAddAddressDialog">取消</button>
        <button class="btn-confirm" bindtap="onSaveNewAddress">保存</button>
      </view>
    </view>
  </view>
</view>
