.page {
  width: 100vw;
  min-height: 100vh;
  background-color: #fafafa;
}

.content {
  width: 100vw;
  height: calc(100vh - 80rpx);
}

/* Tab内容区域 */
.tab-content {
  position: relative;
}

.tab-panel {
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.25s ease, transform 0.25s ease;
  pointer-events: none;
}

.tab-panel.active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* 轮播图 */
.banner-section {
  width: 100vw;
  background-color: #f3f3f3;
}

.banner-swiper {
  width: 100vw;
  height: 420rpx;
}

.banner-image {
  width: 100vw;
  height: 100%;
}

/* Tab按钮 */
.tab-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 20rpx 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ececec;
}

.tab-btn {
  flex: none;
  text-align: center;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #6c6c6c;
  background-color: #f5f5f5;
  margin: 0 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  transition: all 0.25s ease;
  white-space: nowrap;
}

.tab-btn.active {
  color: #ffffff;
  background-color: #1f1f1f;
  border-color: #1f1f1f;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
}

/* 内容区域 */
.content-area {
  padding: 24rpx;
}

/* 当前系列 */
.current-series {
  margin-bottom: 56rpx;
}

.series-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1f1f1f;
  text-align: left;
  padding: 20rpx 0;
  letter-spacing: 1rpx;
}

/* 视频播放器 */
.video-wrapper {
  width: 100%;
  margin: 20rpx 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #000000;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.14);
}

.video-player {
  width: 100%;
  height: 400rpx;
}

/* 系列图片 */
.series-image-wrapper {
  width: 100%;
  margin: 20rpx 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #f3f3f3;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
}

.series-image {
  width: 100%;
  height: 400rpx;
}

/* 系列占位符 */
.series-placeholder {
  width: 100%;
  height: 400rpx;
  margin: 20rpx 0 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f7f7f7 0%, #ececec 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 120rpx;
  font-weight: bold;
  color: #d4af37;
}

/* 商品区域 */
.products-section {
  margin-top: 24rpx;
}

.products-empty {
  margin-top: 24rpx;
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1f1f;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #d4af37;
  padding-left: 14rpx;
}

.products-grid {
  display: flex;
  justify-content: space-between;
}

.product-card {
  flex: 1;
  margin: 0 8rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #ededed;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
}

.product-image {
  width: 100%;
  height: 200rpx;
  background-color: #f3f3f3;
}

.product-name {
  display: block;
  font-size: 24rpx;
  color: #2a2a2a;
  padding: 14rpx 10rpx 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 26rpx;
  color: #d4a85a;
  font-weight: bold;
  padding: 4rpx 8rpx 12rpx;
}

/* 其他系列 */
.other-series {
  margin-top: 56rpx;
  padding-top: 44rpx;
  border-top: 1rpx solid #ececec;
}

.other-series .series-name {
  font-size: 32rpx;
  text-align: left;
  padding-left: 14rpx;
  border-left: 4rpx solid #d4af37;
}

/* 富文本内容区域 */
.rich-content-section {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.rich-content-section .series-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #333333;
}

.rich-content-section .rich-text-content {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  padding: 0 12rpx;
}

.rich-content-section .empty-content {
  display: block;
  font-size: 28rpx;
  color: #999999;
  padding: 0 12rpx;
  font-style: italic;
}

/* 品牌内容区域 */
.brand-content {
  padding: 20rpx 0 28rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 1rpx solid #ededed;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.brand-content .rich-text-content {
  display: block;
  font-size: 28rpx;
  color: #1f1f1f;
  line-height: 1.9;
  padding: 0 20rpx;
}

.brand-content .empty-content {
  display: block;
  font-size: 28rpx;
  color: #999999;
  padding: 0 12rpx;
  font-style: italic;
}
