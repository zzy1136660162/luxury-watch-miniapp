.page {
  width: 100vw;
  min-height: 100vh;
  background-color: #ffffff;
}

.content {
  width: 100vw;
  height: calc(100vh - 80rpx);
}

/* 轮播图 */
.banner-section {
  width: 100vw;
  background-color: #f5f5f5;
}

.banner-swiper {
  width: 100vw;
  height: 400rpx;
}

.banner-image {
  width: 100vw;
  height: 100%;
}

/* Tab按钮 */
.tab-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 20rpx;
  background-color: #ffffff;
  border-bottom: 1px solid #e0e0e0;
}

.tab-btn {
  flex: none;
  text-align: center;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  margin: 0 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.tab-btn.active {
  color: #ffffff;
  background-color: #333333;
}

/* 内容区域 */
.content-area {
  padding: 24rpx;
}

/* 当前系列 */
.current-series {
  margin-bottom: 48rpx;
}

.series-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  padding: 24rpx 0;
}

/* 视频播放器 */
.video-wrapper {
  width: 100%;
  margin: 24rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #000000;
}

.video-player {
  width: 100%;
  height: 400rpx;
}

/* 系列图片 */
.series-image-wrapper {
  width: 100%;
  margin: 24rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
}

.series-image {
  width: 100%;
  height: 400rpx;
}

/* 系列占位符 */
.series-placeholder {
  width: 100%;
  height: 400rpx;
  margin: 24rpx 0;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 120rpx;
  font-weight: bold;
  color: #d4a85a;
}

/* 商品区域 */
.products-section {
  margin-top: 24rpx;
}

.products-empty {
  margin-top: 24rpx;
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #333333;
  padding-left: 12rpx;
}

.products-grid {
  display: flex;
  justify-content: space-between;
}

.product-card {
  flex: 1;
  margin: 0 8rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
}

.product-name {
  display: block;
  font-size: 24rpx;
  color: #333333;
  padding: 12rpx 8rpx 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 26rpx;
  color: #d4a85a;
  font-weight: bold;
  padding: 4rpx 8rpx 12rpx;
}

/* 其他系列 */
.other-series {
  margin-top: 48rpx;
  padding-top: 48rpx;
  border-top: 1px solid #e0e0e0;
}

.other-series .series-name {
  font-size: 32rpx;
  text-align: left;
  padding-left: 12rpx;
  border-left: 4rpx solid #333333;
}

/* 富文本内容区域 */
.rich-content-section {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e0e0e0;
}

.rich-content-section .series-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #333333;
}

.rich-content-section .rich-text-content {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  padding: 0 12rpx;
}

.rich-content-section .empty-content {
  display: block;
  font-size: 28rpx;
  color: #999999;
  padding: 0 12rpx;
  font-style: italic;
}

/* 品牌内容区域 */
.brand-content {
  padding: 24rpx 0;
}

.brand-content .rich-text-content {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  padding: 0 12rpx;
}

.brand-content .empty-content {
  display: block;
  font-size: 28rpx;
  color: #999999;
  padding: 0 12rpx;
  font-style: italic;
}
