<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{true}}" color="black" background="#ffffff" showMenu="{{true}}" />

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}" bindrefresherrefresh="onPullDownRefresh" refresher-enabled="{{true}}">
    <!-- Loading State -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- Product Content -->
    <block wx:else>
      <!-- 1. Image Carousel -->
      <view class="carousel-section" wx:if="{{productImages.length > 0}}">
        <swiper class="carousel" indicator-dots="{{productImages.length > 1}}" autoplay="{{true}}" interval="3000" duration="500" circular="{{true}}" bindchange="onImageChange">
          <swiper-item wx:for="{{productImages}}" wx:key="index">
            <image class="carousel-image" src="{{item}}" mode="aspectFill" />
          </swiper-item>
        </swiper>
        
        <view class="carousel-indicators" wx:if="{{productImages.length > 1}}">
          <view class="indicator {{currentImageIndex === index ? 'indicator-active' : ''}}" wx:for="{{productImages}}" wx:key="index"></view>
        </view>
      </view>

      <!-- 2. Title & Series -->
      <view class="title-section">
        <text class="product-series">{{productInfo.series}}</text>
        <text class="product-title">{{productInfo.name}}</text>
        <text class="product-subtitle">{{productInfo.subtitle}}</text>
        <text class="product-price">{{productInfo.price}}</text>
      </view>

      <!-- 3. Highlights Section -->
      <view class="highlights-section" wx:if="{{productInfo.highlights.length > 0}}">
        <view class="highlights-grid">
          <view class="highlight-item" wx:for="{{productInfo.highlights}}" wx:key="index">
            <image class="highlight-icon" src="https://cdn.jsdelivr.net/npm/@material-design-icons/svg@0.14.15/filled/{{item.icon}}.svg" mode="aspectFit" />
            <text class="highlight-title">{{item.title}}</text>
            <text class="highlight-subtitle">{{item.subtitle}}</text>
            <text class="highlight-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 4. Specifications -->
      <view class="specifications-section" wx:if="{{productInfo.specifications.length > 0}}">
        <view class="specifications-card">
          <view class="specifications-header">
            <text class="specifications-title">产品参数</text>
            <text class="specifications-subtitle">Specifications</text>
          </view>
          <view class="specifications-list">
            <view class="spec-item" wx:for="{{productInfo.specifications}}" wx:key="index">
              <view class="spec-left">
                <text class="spec-name">{{item.name}}</text>
                <text class="spec-name-en">{{item.nameEn}}</text>
              </view>
              <text class="spec-value">{{item.value}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 5. Brand Story -->
      <view class="brand-story-section" wx:if="{{brandStory}}">
        <view class="brand-story-card">
          <view class="brand-story-header" id="brandstoryheader">
            <text class="brand-story-title">品牌故事</text>
            <text class="brand-story-subtitle">Brand Story</text>
          </view>
          <view class="brand-story-content" id="brandstorycontent">
            <rich-text nodes="{{brandStory}}"></rich-text>
          </view>
          <!-- <view class="imga">
          <image src="http://localhost:8081/api/images/unnamed%20(3).png" mode="aspectFill" />
          </view> -->
          <button id="brandstorybtn" class="brand-story-btn" bindtap="onExploreHeritage" style="margin-top: 5vh;">探索品牌</button>
        </view>
      </view>

      <!-- 品牌故事默认内容（无brandStory时） -->
      <view class="brand-story-section" wx:else>
        <view class="brand-story-card">
          <view class="brand-story-header" id="brandstoryheader">
            <text class="brand-story-title">品牌故事</text>
            <text class="brand-story-subtitle">Brand Story</text>
          </view>
          <view class="brand-story-content" id="brandstorycontent">
            <text class="brand-story-text">自 18 世纪创立以来，我们始终秉持对精准与艺术的极致追求。每一枚腕表都凝聚了制表大师的心血，代表着对时间的敬意与对工艺的执着。</text>
          </view>
          <view class="imga">
          <image src="http://localhost:8081/api/images/unnamed%20(3).png" mode="aspectFill" />
          </view>
          <button id="brandstorybtn" class="brand-story-btn" bindtap="onExploreHeritage" style="margin-top: 5vh;">探索品牌</button>
        </view>
      </view>

      <!-- 6. Product Content -->
      <view class="content-section" wx:if="{{product.content}}">
        <view class="content-card">
          <view class="content-header">
            <text class="content-title">商品详情</text>
            <text class="content-subtitle">Details</text>
          </view>
          <view class="content-html">
            <text>{{product.content}}</text>
          </view>
        </view>
      </view>

      <!-- Bottom padding for fixed buttons -->
      <view class="bottom-padding"></view>
    </block>
  </scroll-view>

  <!-- Fixed Action Buttons -->
  <view class="action-fixed">
    <button class="action-btn-consult" bindtap="onConsult">咨询顾问</button>
    <button class="action-btn-book" bindtap="onBook">预约到店</button>
  </view>
</view>
