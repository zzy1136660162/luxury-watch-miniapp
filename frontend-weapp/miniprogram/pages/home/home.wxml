<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{false}}" color="black" background="#ffffff" showMenu="{{true}}" />

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}" bindrefresherrefresh="onPullDownRefresh" refresher-enabled="{{true}}">
    <!-- Section 1: Hero Banner -->
    <view class="hero-banner" wx:if="{{heroImage}}">
      <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <text class="hero-title">时间之承</text>
        <text class="hero-subtitle">Heritage of Time</text>
        <view class="hero-divider"></view>
      </view>
    </view>

    <!-- Section 2: New Arrivals -->
    <view class="section section-new-arrivals" wx:if="{{newArrivals.length > 0}}">
      <view class="section-header">
        <text class="section-title">新品推荐</text>
        <text class="section-subtitle">New Arrivals</text>
      </view>

      <view class="products-grid">
        <view class="product-card" wx:for="{{newArrivals}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="product-image-wrapper">
            <image class="product-image" src="{{item.image}}" mode="aspectFill" />
          </view>
          <view class="product-info">
            <text class="product-tag">{{item.tag}}</text>
            <text class="product-name">{{item.name}}</text>
            <view class="discover-link">
              <text>DISCOVER MORE</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Loading State -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- Section 3: Brand Story -->
    <view class="section section-brand-story" wx:if="{{brandStoryImage}}">
      <image class="brand-story-image" src="{{brandStoryImage}}" mode="aspectFill" />
      <view class="brand-story-overlay"></view>
      <view class="brand-story-content">
        <text class="brand-story-title">品牌故事</text>
        <text class="brand-story-subtitle">Our Story</text>
        <text class="brand-story-text">自 18 世纪以来，我们始终秉持对精准与艺术的极致追求。每一枚腕表不仅是时间的记录者，更是世代相传的匠心杰作。</text>
        <button class="brand-story-button" bindtap="onExploreHeritage">品牌馆</button>
      </view>
    </view>

    <!-- Section 4: Hot Series (Products) -->
    <view class="section section-collections" wx:if="{{hotSeries.length > 0}}">
      <view class="section-header-row">
        <view class="section-header">
          <text class="section-title">热门系列</text>
          <text class="section-subtitle">Hot Series</text>
        </view>
        <view class="scroll-arrows">
          <image class="arrow arrow-left {{scrollLeft <= 0 ? 'arrow-disabled' : ''}}" src="https://cdn.jsdelivr.net/npm/@material-design-icons/svg@0.14.15/filled/west.svg" mode="aspectFit" bindtap="onScrollLeft" />
          <image class="arrow arrow-right" src="https://cdn.jsdelivr.net/npm/@material-design-icons/svg@0.14.15/filled/east.svg" mode="aspectFit" bindtap="onScrollRight" />
        </view>
      </view>

      <scroll-view id="collectionsScroll" class="collections-scroll" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" scroll-left="{{scrollLeft}}" bindscroll="onCollectionScroll">
        <view class="collections-track">
          <view class="collection-item" wx:for="{{hotSeries}}" wx:key="id" bindtap="onHotSeriesTap" data-id="{{item.id}}">
            <view class="collection-image-wrapper">
              <image class="collection-image" src="{{item.image}}" mode="aspectFill" />
            </view>
            <text class="collection-name">{{item.name}}</text>
            <text class="collection-desc">{{item.description}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- Section 5: Featured Products - 精选腕表模块 -->
    <view class="section section-featured" wx:if="{{featuredProducts.length > 0}}">
      <view class="section-header">
        <text class="section-title">精选腕表</text>
        <text class="section-subtitle">Featured Timepieces</text>
      </view>

      <view class="featured-grid">
        <view class="featured-card {{index === 0 ? 'featured-card-first' : ''}} {{index === 1 ? 'featured-card-second' : ''}} {{index === 2 ? 'featured-card-third' : ''}} {{index === 3 ? 'featured-card-fourth' : ''}} {{index === 4 ? 'featured-card-fifth' : ''}} {{index === 5 ? 'featured-card-sixth' : ''}}" wx:for="{{featuredProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="featured-image-wrapper">
            <image class="featured-image" src="{{item.image}}" mode="aspectFill" />
            <!-- 产品标签 -->
            <view class="featured-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          </view>
          <view class="featured-info {{index === 0 ? 'featured-info-first' : ''}} {{index === 1 ? 'featured-info-second' : ''}} {{index === 2 ? 'featured-info-third' : ''}} {{index === 3 ? 'featured-info-fourth' : ''}} {{index === 4 ? 'featured-info-fifth' : ''}} {{index === 5 ? 'featured-info-sixth' : ''}}">
            <text class="featured-name">{{item.name}}</text>
            <text class="featured-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
            <text class="featured-price" wx:if="{{item.price && index !== 0 && index !== 1 && index !== 2 && index !== 3 && index !== 4 && index !== 5}}">¥{{item.price}}</text>
            <!-- 商品详情介绍（仅前六个商品） -->
            <text class="featured-description" wx:if="{{index === 0}}">这款腕表融合了精湛工艺与经典设计，采用优质材料打造，展现出卓越的品质和优雅的风格。</text>
            <text class="featured-description" wx:if="{{index === 1}}">此款腕表以其独特的设计理念和卓越的性能著称，完美诠释了现代制表工艺的精髓。</text>
            <text class="featured-description" wx:if="{{index === 2}}">这款腕表体现了对细节的极致追求，每一处设计都彰显着非凡的品味与格调。</text>
            <text class="featured-description" wx:if="{{index === 3}}">这款腕表以其优雅的外观和卓越的性能，成为时尚与功能的完美结合。</text>
            <text class="featured-description" wx:if="{{index === 4}}">这款腕表凭借其卓越的工艺和独特的设计，成为收藏家们的心头好。</text>
            <text class="featured-description" wx:if="{{index === 5}}">这款腕表以其创新的技术和精湛的工艺，重新定义了现代腕表的标杆。</text>
            <!-- 查看详情按钮 -->
            <view class="featured-action {{index === 0 ? 'featured-action-first' : ''}} {{index === 1 ? 'featured-action-second' : ''}} {{index === 2 ? 'featured-action-third' : ''}} {{index === 3 ? 'featured-action-fourth' : ''}} {{index === 4 ? 'featured-action-fifth' : ''}} {{index === 5 ? 'featured-action-sixth' : ''}}">
              <text>查看详情</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Footer -->
  </scroll-view>
</view>
