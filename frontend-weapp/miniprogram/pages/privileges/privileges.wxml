<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{true}}" color="black" background="#ffffff" />

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}">
    <!-- Hero Section -->
    <view class="hero-section {{heroImage ? '' : 'hero-no-image'}}">
      <image wx:if="{{heroImage}}" class="hero-image" src="{{heroImage}}" mode="aspectFill" binderror="onImageError" data-type="hero" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <text class="hero-label">EXCLUSIVE PRIVILEGES</text>
        <text class="hero-title">尊享礼遇</text>
        <view class="points-display">
          <text class="points-label">当前积分 | POINTS</text>
          <text class="points-value">{{memberPoints}}</text>
        </view>
      </view>
    </view>

    <!-- Rewards Section -->
    <view class="rewards-section">
      <!-- Empty State -->
      <view wx:if="{{products.length === 0}}" class="empty-state">
        <text class="empty-title">暂无可兑换商品</text>
        <text class="empty-desc">敬请期待更多精彩礼遇</text>
      </view>

      <!-- Products List -->
      <block wx:for="{{products}}" wx:key="id">
        <!-- Product Card -->
        <view class="product-card" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="product-image-wrapper {{item.image ? '' : 'image-placeholder'}}">
            <image wx:if="{{item.image}}" class="product-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
          </view>
          <view class="product-content">
            <view class="product-header">
              <text class="product-tag">{{item.tag}}</text>
              <text class="product-title">{{item.title}}</text>
            </view>
            <text class="product-desc">{{item.desc}}</text>
            <view class="product-footer">
              <view class="product-points">
                <text class="points-value">{{item.points}}</text>
                <text class="points-unit">POINTS</text>
              </view>
              <button class="redeem-btn" catchtap="onRedeem" data-id="{{item.id}}">立即兑换</button>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- Secondary Info Section -->
    <view class="info-section">
      <view class="info-content">
        <text class="info-title">礼遇服务说明</text>
        <text class="info-text">所有礼遇项兑换需遵循《会员积分手册》。兑换后的实物礼品将在15个工作日内寄出，线下活动请提前3天确认出席。积分一经扣除，非质量问题不予退还。</text>
      </view>

      <view class="info-links">
        <view class="links-column">
          <text class="links-label">LINKS</text>
          <view class="link-item">
            <text>积分说明 | RULES</text>
          </view>
          <view class="link-item" bindtap="onViewExchangeRecords">
            <text>兑换记录 | RECORDS</text>
          </view>
        </view>

        <view class="links-column">
          <text class="links-label">SUPPORT</text>
          <view class="link-item">
            <text>联系管家 | CONCIERGE</text>
          </view>
          <view class="link-item">
            <text>常见问题 | FAQ</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
