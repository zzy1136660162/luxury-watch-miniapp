<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{true}}" color="black" background="#ffffff" />

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}">
    <!-- Hero Section -->
    <view class="hero-section">
      <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <text class="hero-label">EXCLUSIVE PRIVILEGES</text>
        <text class="hero-title">尊享礼遇</text>
        <view class="points-display">
          <text class="points-label">当前积分 | POINTS</text>
          <text class="points-value">{{memberPoints}}</text>
        </view>
      </view>
    </view>

    <!-- Navigation Tabs -->
    <view class="tabs-nav">
      <scroll-view class="tabs-scroll" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="tabs-track">
          <view 
            class="tab-item {{currentTab === 'classic' ? 'tab-active' : ''}}" 
            bindtap="onTabTap" 
            data-tab="classic"
          >
            <text>经典礼赞</text>
          </view>
          <view 
            class="tab-item {{currentTab === 'accessories' ? 'tab-active' : ''}}" 
            bindtap="onTabTap" 
            data-tab="accessories"
          >
            <text>品牌周边</text>
          </view>
          <view 
            class="tab-item {{currentTab === 'offline' ? 'tab-active' : ''}}" 
            bindtap="onTabTap" 
            data-tab="offline"
          >
            <text>线下邀约</text>
          </view>
          <view 
            class="tab-item {{currentTab === 'services' ? 'tab-active' : ''}}" 
            bindtap="onTabTap" 
            data-tab="services"
          >
            <text>服务特权</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- Rewards Bento Grid -->
    <view class="rewards-section">
      <!-- Main Featured Card -->
      <view class="featured-card" bindtap="onProductTap" data-id="featured1">
        <view class="featured-image-wrapper">
          <image class="featured-image" src="{{featuredProduct.image}}" mode="aspectFill" />
        </view>
        <view class="featured-content">
          <text class="featured-tag">ACCESSORIES</text>
          <text class="featured-title">高级鳄鱼皮表带</text>
          <text class="featured-desc">甄选密西西比鳄鱼腹皮，纯手工缝制，呈现无与伦比的质感与耐用性。</text>
          <view class="featured-footer">
            <text class="featured-points">8,000 <text class="points-unit">POINTS</text></text>
            <button class="redeem-btn" data-id="featured1">立即兑换</button>
          </view>
        </view>
      </view>

      <!-- Two-Column Grid -->
      <view class="rewards-grid">
        <!-- Silk Scarf Card -->
        <view class="reward-card" bindtap="onProductTap" data-id="silk1">
          <view class="reward-image-wrapper">
            <image class="reward-image" src="{{silkScarf.image}}" mode="aspectFill" />
          </view>
          <view class="reward-content">
            <view class="reward-header">
              <view class="reward-info">
                <text class="reward-tag">LIMITED EDITION</text>
                <text class="reward-title">周年限量丝巾</text>
              </view>
              <text class="reward-points">5,000 <text class="points-unit">PTS</text></text>
            </view>
            <text class="reward-desc">与先锋艺术家联名创作，将时间的律动化为指尖的丝滑艺术。</text>
            <view class="reward-link">
              <text>DISCOVER MORE</text>
            </view>
          </view>
        </view>

        <!-- Private Event Card -->
        <view class="reward-card" bindtap="onProductTap" data-id="event1">
          <view class="reward-image-wrapper">
            <image class="reward-image" src="{{privateEvent.image}}" mode="aspectFill" />
          </view>
          <view class="reward-content">
            <view class="reward-header">
              <view class="reward-info">
                <text class="reward-tag">OFFLINE EXPERIENCE</text>
                <text class="reward-title">私人品鉴会邀请函</text>
              </view>
              <text class="reward-points reward-points-gold">12,000 <text class="points-unit">PTS</text></text>
            </view>
            <text class="reward-desc">亲临品牌年度私密晚宴，与制表大师面对面交流，探索未公开的传世新作。</text>
            <view class="reward-link">
              <text>RESERVE SEAT</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Secondary Info Section -->
    <view class="info-section">
      <view class="info-content">
        <text class="info-title">礼遇服务说明</text>
        <text class="info-text">所有礼遇项兑换需遵循《会员积分手册》。兑换后的实物礼品将在15个工作日内寄出，线下活动请提前3天确认出席。积分一经扣除，非质量问题不予退还。</text>
      </view>

      <view class="info-links">
        <view class="links-column">
          <text class="links-label">LINKS</text>
          <view class="link-item">
            <text>积分说明 | RULES</text>
          </view>
          <view class="link-item">
            <text>兑换历史 | HISTORY</text>
          </view>
        </view>

        <view class="links-column">
          <text class="links-label">SUPPORT</text>
          <view class="link-item">
            <text>联系管家 | CONCIERGE</text>
          </view>
          <view class="link-item">
            <text>常见问题 | FAQ</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
