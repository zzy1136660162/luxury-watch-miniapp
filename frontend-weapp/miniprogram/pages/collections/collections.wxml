<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{false}}" color="black" background="#ffffff" showMenu="{{true}}" />

  <!-- 固定在顶部的分类导航栏（滚动时显示） -->
  <!-- <view class="category-nav-fixed {{isNavFixed ? 'show' : ''}}">
    <scroll-view class="category-scroll" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="category-track">
        <view class="category-item {{currentCategory === 'all' ? 'category-active' : ''}}" bindtap="onCategoryTap" data-category="all">
          <text class="category-name">全部</text>
          <text class="category-name-en">All</text>
        </view>
        <view class="category-item {{currentCategory === item.code ? 'category-active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-category="{{item.code}}">
          <text class="category-name">{{item.name}}</text>
          <text class="category-name-en">{{item.nameEn || item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view> -->

  <!-- 固定在左侧的品牌导航栏（滚动时显示） -->
  <view class="brand-sidebar-fixed-v2 {{isNavFixed ? 'show' : ''}}">
    <view class="brand-sidebar-title" bindtap="onSearchTap">
      <image class="search-icon" src="/assets/iconfont/search.png" mode="aspectFit" />
    </view>
    <scroll-view class="brand-sidebar-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="brand-sidebar-track">
        <view class="brand-sidebar-item {{currentBrand === item ? 'brand-sidebar-active' : ''}}" wx:for="{{brands}}" wx:key="index" bindtap="onBrandTap" data-brand="{{item}}">
          <text class="brand-sidebar-name">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}" bindscroll="onScroll" id="main-scroll" bindrefresherrefresh="onPullDownRefresh" refresher-enabled="{{true}}" bindscrolltolower="onReachBottom">
    <!-- Hero Banner -->
    <view class="hero-banner" id="hero-banner" wx:if="{{heroImage}}">
      <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <text class="hero-title">永恒之艺</text>
        <text class="hero-subtitle">The Art of Eternity</text>
        <view class="hero-divider"></view>
      </view>
    </view>

    <!-- 带侧边栏的内容区域 -->
    <view class="content-with-sidebar">
      <!-- 左侧品牌导航栏 -->
      <view class="brand-sidebar">
      <view class="brand-sidebar-title" bindtap="onSearchTap">
      <image class="search-icon" src="/assets/iconfont/search.png" mode="aspectFit" />
    </view>
        <scroll-view class="brand-sidebar-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
          <view class="brand-sidebar-track">
            <view class="brand-sidebar-item {{currentBrand === item ? 'brand-sidebar-active' : ''}}" wx:for="{{brands}}" wx:key="index" bindtap="onBrandTap" data-brand="{{item}}">
              <text class="brand-sidebar-name">{{item}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 右侧产品列表 -->
      <view class="products-area">
        <!-- Category Navigation（元素内导航栏，初始显示） -->
        <!-- <view class="category-nav" id="category-nav">
          <scroll-view class="category-scroll" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}">
            <view class="category-track">
              <view class="category-item {{currentCategory === 'all' ? 'category-active' : ''}}" bindtap="onCategoryTap" data-category="all">
                <text class="category-name">全部</text>
                <text class="category-name-en">All</text>
              </view>
              <view class="category-item {{currentCategory === item.code ? 'category-active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-category="{{item.code}}">
                <text class="category-name">{{item.name}}</text>
                <text class="category-name-en">{{item.nameEn || item.name}}</text>
              </view>
            </view>
          </scroll-view>
        </view> -->

        <!-- 系列列表（根据品牌显示） -->
        <view class="series-section" wx:if="{{categorySeries.length > 0}}">
          <view class="section-title">
            <text class="title-text">系列列表</text>
            <text class="title-en">SERIES LIST</text>
          </view>
          <view class="series-grid">
            <view class="series-item" wx:for="{{categorySeries}}" wx:key="index" bindtap="onSeriesItemTap" data-brand="{{item.brand}}" data-series="{{item.series}}">
              <view class="series-content">
                <image class="series-logo" src="{{item.logo}}" mode="aspectFit" wx:if="{{item.logo}}" />
                <text class="series-name">{{item.brand}} - {{item.series}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
