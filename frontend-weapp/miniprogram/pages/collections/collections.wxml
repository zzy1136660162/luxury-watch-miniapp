<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="时全饰美" back="{{false}}" color="black" background="#ffffff" showMenu="{{true}}" />

  <!-- 固定在左侧的品牌导航栏（滚动时显示） -->
  <view class="brand-sidebar-fixed-v2 {{isNavFixed ? 'show' : ''}}">
    <view class="brand-sidebar-title" bindtap="onSearchTap">
      <image class="search-icon" src="/assets/iconfont/search.png" mode="aspectFit" />
    </view>
    <scroll-view class="brand-sidebar-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="brand-sidebar-track">
        <view class="brand-sidebar-item {{currentBrand === item ? 'brand-sidebar-active' : ''}}" wx:for="{{brands}}" wx:key="index" bindtap="onBrandTap" data-brand="{{item}}" data-index="{{index}}">
          <text class="brand-sidebar-name">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="content" scroll-y type="list" enhanced="{{true}}" bounces="{{false}}" bindscroll="onScroll" id="main-scroll" scroll-into-view="{{scrollIntoView}}" bindrefresherrefresh="onPullDownRefresh" refresher-enabled="{{true}}">
    <!-- Hero Banner -->
    <view class="hero-banner" id="hero-banner" wx:if="{{heroImage}}">
      <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-content">
        <text class="hero-title">永恒之艺</text>
        <text class="hero-subtitle">The Art of Eternity</text>
        <view class="hero-divider"></view>
      </view>
    </view>

    <!-- 带侧边栏的内容区域 -->
    <view class="content-with-sidebar">
      <!-- 左侧品牌导航栏 -->
      <view class="brand-sidebar">
        <view class="brand-sidebar-title" bindtap="onSearchTap">
          <image class="search-icon" src="/assets/iconfont/search.png" mode="aspectFit" />
        </view>
        <scroll-view class="brand-sidebar-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
          <view class="brand-sidebar-track">
            <view class="brand-sidebar-item {{currentBrand === item ? 'brand-sidebar-active' : ''}}" wx:for="{{brands}}" wx:key="index" bindtap="onBrandTap" data-brand="{{item}}" data-index="{{index}}">
              <text class="brand-sidebar-name">{{item}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 右侧品牌系列列表 -->
      <view class="products-area">
        <!-- 按品牌分组的系列列表 -->
        <view class="brand-series-section" wx:for="{{brandSeriesList}}" wx:key="brand" id="brand-{{index}}">
          <!-- 品牌标题 -->
          <view class="brand-title">
            <text class="brand-name">{{item.brand}}</text>
          </view>
          <!-- 该品牌的系列网格 -->
          <view class="series-grid" wx:if="{{item.series.length > 0}}">
            <view class="series-card" wx:for="{{item.series}}" wx:key="name" wx:for-item="seriesItem" bindtap="onSeriesItemTap" data-brand="{{item.brand}}" data-series="{{seriesItem.name}}">
              <view class="series-image-wrapper">
                <!-- 有logo时显示图片 -->
                <block wx:if="{{seriesItem.logo}}">
                  <image class="series-image" src="{{seriesItem.logo}}" mode="aspectFill" binderror="onImageError" data-series="{{seriesItem.name}}" lazy-load="{{true}}" />
                </block>
                <!-- 无logo时显示占位符 -->
                <block wx:else>
                  <view class="series-image-placeholder">
                    <text class="placeholder-text">{{seriesItem.name[0]}}</text>
                  </view>
                </block>
              </view>
              <text class="series-card-name">{{seriesItem.name}}</text>
            </view>
          </view>
          <view class="series-empty" wx:else>
            <text class="empty-text">暂无系列</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
