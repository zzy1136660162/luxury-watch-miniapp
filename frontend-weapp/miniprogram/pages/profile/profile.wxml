<view class="page">
  <view class="nav-bar">
    <view class="nav-bar-left" bindtap="onBack">
      <text class="back-arrow">‹</text>
    </view>
    <view class="nav-bar-title">个人信息</view>
    <view class="nav-bar-right"></view>
  </view>

  <view class="profile-container">
    <view class="profile-header">
      <view class="avatar-section">
        <view class="avatar-wrapper">
          <image class="avatar-image" src="{{userAvatar}}" mode="aspectFill" />
        </view>
        <view class="level-badge">
          <text class="level-text">{{memberLevelName}}</text>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-card">
        <view class="info-item">
          <view class="info-left">
            <text class="info-label">用户名</text>
          </view>
          <view class="info-right">
            <text class="info-value">{{username}}</text>
          </view>
        </view>

        <view class="info-divider"></view>

        <view class="info-item">
          <view class="info-left">
            <text class="info-label">手机号</text>
          </view>
          <view class="info-right">
            <text class="info-value">{{phone}}</text>
          </view>
        </view>

        <view class="info-divider"></view>

        <view class="info-item">
          <view class="info-left">
            <text class="info-label">会员等级</text>
          </view>
          <view class="info-right">
            <text class="info-value highlight">{{memberLevelName}}</text>
          </view>
        </view>

        <view class="info-divider"></view>

        <view class="info-item">
          <view class="info-left">
            <text class="info-label">积分</text>
          </view>
          <view class="info-right">
            <text class="info-value points">{{points}}</text>
          </view>
        </view>

        <view class="info-divider"></view>

        <view class="info-item">
          <view class="info-left">
            <text class="info-label">成长值</text>
          </view>
          <view class="info-right">
            <text class="info-value growth">{{growthValue}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tips-section">
      <text class="tips-text" wx:if="{{nextLevelGrowth > 0}}">成长值达到 {{nextLevelGrowth}} 可升级为 {{nextLevelName}}</text>
      <text class="tips-text" wx:if="{{nextLevelGrowth === 0}}">已是最高等级会员</text>
    </view>
  </view>
</view>
