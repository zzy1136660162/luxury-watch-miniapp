<import src="/components/navigation-bar/navigation-bar.wxml" />

<view class="page">
  <navigation-bar title="登录" back="{{true}}" color="black" background="#ffffff" />

  <view class="login-container">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-wrapper {{hasAvatar ? 'has-avatar' : ''}}">
          <image wx:if="{{hasAvatar}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-text">点击</text>
          </view>
        </view>
        <view class="avatar-hint">{{hasAvatar ? '已授权' : '点击授权微信头像'}}</view>
      </button>
    </view>

    <view class="logo-section">
      <text class="brand-name">时全饰美</text>
      <text class="brand-subtitle">LUXURY WATCH</text>
    </view>

    <view class="form-section">
      <view class="input-group">
        <view class="input-wrapper {{phoneFocus ? 'input-focus' : ''}}">
          <image class="input-icon" src="{{icons.phone}}" mode="aspectFit" />
          <input 
            class="input-field"
            type="number"
            placeholder="请输入手机号"
            placeholder-class="placeholder"
            value="{{phone}}"
            maxlength="11"
            bindinput="onPhoneInput"
            bindfocus="onPhoneFocus"
            bindblur="onPhoneBlur"
          />
        </view>
      </view>

      <view class="input-group">
        <view class="input-wrapper {{usernameFocus ? 'input-focus' : ''}}">
          <image class="input-icon" src="{{icons.username}}" mode="aspectFit" />
          <input 
            class="input-field"
            type="text"
            placeholder="请输入用户名"
            placeholder-class="placeholder"
            value="{{username}}"
            bindinput="onUsernameInput"
            bindfocus="onUsernameFocus"
            bindblur="onUsernameBlur"
          />
        </view>
      </view>

      <view class="input-group">
        <view class="input-wrapper {{passwordFocus ? 'input-focus' : ''}}">
          <image class="input-icon" src="{{icons.password}}" mode="aspectFit" />
          <input 
            class="input-field"
            password="{{!showPassword}}"
            placeholder="请输入密码"
            placeholder-class="placeholder"
            value="{{password}}"
            bindinput="onPasswordInput"
            bindfocus="onPasswordFocus"
            bindblur="onPasswordBlur"
          />
          <view class="password-toggle" bindtap="togglePasswordVisibility">
            <text class="toggle-text {{showPassword ? 'toggle-active' : ''}}">{{showPassword ? '隐藏' : '显示'}}</text>
          </view>
        </view>
      </view>

      <button 
        class="login-btn {{loading ? 'btn-disabled' : ''}}" 
        bindtap="onLogin"
        disabled="{{loading}}"
      >
        <text class="btn-text" wx:if="{{!loading}}">登 录</text>
        <text class="btn-text" wx:else>登录中...</text>
      </button>

      <view class="tips-section">
        <text class="tips-text">登录即表示同意</text>
        <text class="tips-link" bindtap="onUserAgreement">《用户协议》</text>
        <text class="tips-text">和</text>
        <text class="tips-link" bindtap="onPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>

    <view class="footer-section">
      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">其他登录方式</text>
        <view class="divider-line"></view>
      </view>
    </view>
  </view>
</view>
