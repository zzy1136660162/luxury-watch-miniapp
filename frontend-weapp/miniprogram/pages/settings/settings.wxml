<view class="page">
  <view class="nav-bar">
    <view class="nav-bar-left" bindtap="onBack">
      <text class="back-arrow">‹</text>
    </view>
    <view class="nav-bar-title">设置</view>
    <view class="nav-bar-right"></view>
  </view>

  <view class="settings-container">
    <view class="settings-list">
      <view class="settings-item" bindtap="onProfileTap">
        <view class="item-left">
          <text class="item-icon-text">👤</text>
          <text class="item-name">个人信息</text>
        </view>
        <text class="item-arrow-text">›</text>
      </view>

      <view class="settings-item" bindtap="onLogoutTap">
        <view class="item-left">
          <text class="item-icon-text">🚪</text>
          <text class="item-name">退出登录</text>
        </view>
        <text class="item-arrow-text">›</text>
      </view>
    </view>

    <view class="version-info">
      <text class="version-text">时全饰美 v1.0.0</text>
    </view>
  </view>
</view>
